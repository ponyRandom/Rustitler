{
  "productName": "Rustitler",
  "version": "0.1.0",
  "identifier": "com.rustitler.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Rustitler",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 520
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/tessdata": "tessdata",
      "resources/pdfium": "pdfium",
      "resources/libreoffice": "libreoffice"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
