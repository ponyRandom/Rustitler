{
  "name": "rustitler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:node-scripts": "node --test scripts/module-entry.node-test.mjs scripts/prepare-offline-assets.node-test.mjs scripts/package-size-report.node-test.mjs scripts/offline-package-workflow.node-test.mjs",
    "test:offline-assets": "node --test scripts/prepare-offline-assets.node-test.mjs",
    "test:offline-package-workflow": "node --test scripts/offline-package-workflow.node-test.mjs",
    "test:package-size-report": "node --test scripts/package-size-report.node-test.mjs",
    "prepare:offline-assets": "node scripts/prepare-offline-assets.mjs",
    "package:size-report": "node scripts/package-size-report.mjs",
    "tauri:build:offline": "npm run prepare:offline-assets && tauri build --features offline-bundle",
    "tauri:build:offline:ci": "npm run prepare:offline-assets -- --download && tauri build --features offline-bundle",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^4.1.9"
  }
}
